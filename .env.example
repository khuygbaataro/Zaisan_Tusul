# Copy to `.env` (which is gitignored) and fill in real values for local dev.
# On Render: set these in the service's Environment tab — never commit real secrets.

# === Anthropic Claude API ===
ANTHROPIC_API_KEY=
# Highest-quality model for the customer-facing bot.
ANTHROPIC_MODEL=claude-opus-4-7

# === Facebook Messenger ===
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
# Pick any string you want — you'll paste the same value into the Facebook
# webhook setup screen so FB and the bot can verify each other.
FACEBOOK_VERIFY_TOKEN=zaisan-verify-pick-anything

# === Firebase Admin (for conversation logging & first-contact detection) ===
# Paste the raw service-account JSON on a single line, or base64-encode it.
FIREBASE_SERVICE_ACCOUNT=

# === Optional ===
PORT=8080
# Public URL of THIS bot service. Used to build image attachment URLs that FB
# can fetch (e.g. https://your-bot.onrender.com/public/gadna1.jpg).
# On Render this is auto-populated as RENDER_EXTERNAL_URL — you usually don't
# need to set PUBLIC_SITE_URL manually.
PUBLIC_SITE_URL=
